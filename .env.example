# Backend (.env)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/insightrag?sslmode=require
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
JWT_SECRET=generate-a-strong-random-secret-at-least-32-chars

# Admin
ADMIN_EMAIL=admin@example.com

# === LOCAL DEVELOPMENT ===
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
NODE_ENV=development

# === PRODUCTION ===
# Backend on Render:
#   FRONTEND_URL=https://your-vercel-project.vercel.app
#   BACKEND_URL=https://insightrag-backend.onrender.com
#   GOOGLE_CALLBACK_URL=https://insightrag-backend.onrender.com/api/auth/google/callback
#   NODE_ENV=production

# AI & Vector DB
GEMINI_API_KEY=your-gemini-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=your-index-name

# === Frontend (frontend/.env) ===
# Cross-origin: frontend on Vercel, backend on Render
# VITE_API_URL=https://your-backend.onrender.com/api
